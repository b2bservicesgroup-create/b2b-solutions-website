---
const solutions = [
  { href: '/solutions/bookkeeping', label: 'Bookkeeping' },
  { href: '/solutions/hr-solutions', label: 'HR Solutions' },
  { href: '/solutions/payroll-administration', label: 'Payroll Administration' },
  { href: '/solutions/administrative-support', label: 'Administrative Support' },
  { href: '/solutions/document-creation', label: 'Document Creation & SOPs' },
  { href: '/solutions/llc-registration', label: 'LLC Registration' },
];

const quickLinks = [
  { href: '/', label: 'Home' },
  { href: '/solutions', label: 'Solutions' },
  { href: '/network', label: 'Our Network' },
  { href: '/about', label: 'About Us' },
  { href: '/faq', label: 'FAQ' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <div>
        <a href="/" class="inline-block mb-4">
          <img src="/logo.png" alt="B2B Solutions" class="h-10 w-auto brightness-0 invert" />
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
          Helping small businesses thrive with professional services tailored to your needs and budget.
        </p>
        <div class="mt-4 flex gap-2">
          <a
            href="https://www.facebook.com/b2bsolutionsbiz"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="B2B Solutions on Facebook"
            class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-gray-800 text-gray-400 hover:bg-blue-600 hover:text-white transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" />
            </svg>
          </a>
          <a
            href="https://share.google/ujIOfipPqlPWw3kVa"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="B2B Solutions on Google"
            class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-gray-800 text-gray-400 hover:bg-red-500 hover:text-white transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z" />
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/company/b2bsolutions"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="B2B Solutions on LinkedIn"
            class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-gray-800 text-gray-400 hover:bg-blue-700 hover:text-white transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Quick Links</h3>
        <ul class="space-y-2.5">
          {quickLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-gray-400 hover:text-blue-400 transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Our Solutions</h3>
        <ul class="space-y-2.5">
          {solutions.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-gray-400 hover:text-blue-400 transition-colors">{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">Contact Us</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 mt-0.5 text-blue-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@b2bsolutions.biz" class="text-sm text-gray-400 hover:text-blue-400 transition-colors break-all">
              info@b2bsolutions.biz
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 mt-0.5 text-blue-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <div class="text-sm">
              <a href="tel:3605292672" class="text-gray-400 hover:text-blue-400 transition-colors block">360-529-2672 (West Coast)</a>
              <a href="tel:3194510501" class="text-gray-400 hover:text-blue-400 transition-colors block">319-451-0501 (Midwest)</a>
            </div>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 mt-0.5 text-blue-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <div class="text-sm text-gray-400">
              <span class="block">Rochester, WA</span>
              <span class="block">Cedar Rapids, IA</span>
            </div>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-12 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-sm text-gray-500">
        &copy; {new Date().getFullYear()} B2B Solutions. All rights reserved.
      </p>
      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
        <a href="/privacy-policy" class="hover:text-gray-300 transition-colors">Privacy Policy</a>
        <span class="text-gray-700">&bull;</span>
        <a href="/terms-of-service" class="hover:text-gray-300 transition-colors">Terms of Service</a>
        <span class="text-gray-700">&bull;</span>
        <span>Rochester, WA &bull; Cedar Rapids, IA</span>
      </div>
    </div>
  </div>
</footer>
