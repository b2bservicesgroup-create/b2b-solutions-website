---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    icon: 'calculator',
    title: 'Bookkeeping',
    description: 'Accurate financial records, reconciliations, and monthly reporting so you always know where your business stands.',
    href: '/solutions/bookkeeping',
  },
  {
    icon: 'users',
    title: 'HR Solutions',
    description: 'Professional HR expertise without the full-time cost — employee relations, policies, compliance, and more.',
    href: '/solutions/hr-solutions',
  },
  {
    icon: 'dollar',
    title: 'Payroll Administration',
    description: 'Accurate, on-time payroll with tax filings, direct deposit, and complete records management.',
    href: '/solutions/payroll-administration',
  },
  {
    icon: 'clipboard',
    title: 'Administrative Support',
    description: 'Virtual administrative assistance to keep your day-to-day operations running smoothly.',
    href: '/solutions/administrative-support',
  },
  {
    icon: 'document',
    title: 'Document Creation & SOPs',
    description: 'Professional documentation — from SOPs to proposals to employee handbooks — tailored to your business.',
    href: '/solutions/document-creation',
  },
  {
    icon: 'building',
    title: 'LLC Registration & Registered Agent',
    description: 'Form your LLC and appoint B2B Solutions as your registered agent in Washington State — fast and hassle-free.',
    href: '/solutions/llc-registration',
  },
  {
    icon: 'network',
    title: 'Professional Network',
    description: 'Access our trusted network of attorneys, tax pros, marketing experts, and print specialists.',
    href: '/network',
  },
];

const reasons = [
  {
    title: 'Cost-Effective',
    description: 'Professional expertise without the overhead of a full-time employee. Pay for exactly what you need.',
  },
  {
    title: 'Flexible & Scalable',
    description: 'Services that grow with your business. Start small and expand as your needs evolve.',
  },
  {
    title: 'Experienced Professionals',
    description: 'Deep expertise in small business operations across multiple industries and service areas.',
  },
  {
    title: 'Network Access',
    description: 'One relationship unlocks a full network of vetted specialists for any business need.',
  },
];
---

<Layout title="Home">
  <Header />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-blue-900 via-blue-800 to-blue-700 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 bg-white bg-opacity-10 rounded-full px-4 py-1.5 text-blue-100 text-sm font-medium mb-6">
          <span class="w-2 h-2 rounded-full bg-blue-300 shrink-0"></span>
          Serving Rochester, WA &amp; Cedar Rapids, IA
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Big Business Solutions<br />
          <span class="text-blue-300">for Small Business Success</span>
        </h1>
        <p class="text-lg md:text-xl text-blue-100 mb-8 leading-relaxed max-w-2xl">
          B2B Solutions partners with small businesses to provide the professional services they need — bookkeeping, HR, payroll, administrative support, and more — so you can focus on what you do best.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="/solutions" class="bg-white text-blue-800 px-6 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors">
            Explore Our Solutions
          </a>
          <a href="/contact" class="border-2 border-white text-white px-6 py-3 rounded-lg font-semibold hover:bg-white hover:text-blue-800 transition-colors">
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Our Solutions</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Comprehensive business support services designed to help small businesses operate efficiently and grow with confidence.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(({ icon, title, description, href }) => (
          <a href={href} class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow border border-gray-100 group flex flex-col">
            <div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center mb-4 group-hover:bg-blue-100 transition-colors">
              {icon === 'calculator' && (
                <svg class="w-6 h-6 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                </svg>
              )}
              {icon === 'users' && (
                <svg class="w-6 h-6 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
              )}
              {icon === 'dollar' && (
                <svg class="w-6 h-6 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              )}
              {icon === 'clipboard' && (
                <svg class="w-6 h-6 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                </svg>
              )}
              {icon === 'document' && (
                <svg class="w-6 h-6 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              )}
              {icon === 'building' && (
                <svg class="w-6 h-6 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              )}
              {icon === 'network' && (
                <svg class="w-6 h-6 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                </svg>
              )}
            </div>
            <h3 class="font-bold text-gray-900 text-lg mb-2">{title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed flex-grow">{description}</p>
            <span class="mt-4 inline-flex items-center text-blue-700 text-sm font-semibold">
              Learn more
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
            Why Small Businesses Choose B2B Solutions
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4">
            Running a small business is demanding. You wear many hats — but you don't have to wear all of them. B2B Solutions gives you access to professional-grade services at a fraction of what it costs to hire in-house.
          </p>
          <p class="text-gray-600 leading-relaxed mb-8">
            Whether you're a solo operator or a growing team, our flexible service model means you get exactly what you need, when you need it.
          </p>
          <a href="/about" class="inline-flex items-center text-blue-700 font-semibold hover:text-blue-800 transition-colors">
            Learn about us
            <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {reasons.map(({ title, description }) => (
            <div class="bg-gray-50 rounded-xl p-5 border border-gray-100">
              <div class="w-8 h-8 bg-blue-800 rounded-lg flex items-center justify-center mb-3">
                <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <h3 class="font-bold text-gray-900 mb-1.5">{title}</h3>
              <p class="text-sm text-gray-600 leading-relaxed">{description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Network Teaser -->
  <section class="py-16 md:py-20 bg-blue-800 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Our Professional Network</h2>
      <p class="text-blue-200 text-lg max-w-2xl mx-auto mb-8">
        Beyond our core services, we connect you with our trusted network of professionals to help with every aspect of your business.
      </p>
      <div class="flex flex-wrap justify-center gap-3 mb-10">
        {['Attorneys', 'Tax Professionals', 'Marketing Experts', 'Print &amp; Merchandise'].map((item) => (
          <span class="bg-white bg-opacity-10 text-blue-100 border border-white border-opacity-20 px-4 py-2 rounded-full text-sm font-medium" set:html={item} />
        ))}
      </div>
      <a href="/network" class="inline-block bg-white text-blue-800 px-7 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors">
        Explore Our Network
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Ready to Streamline Your Business?
      </h2>
      <p class="text-lg text-gray-600 mb-8">
        Let's talk about how B2B Solutions can help your business run more efficiently and grow with confidence.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contact" class="bg-blue-800 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-900 transition-colors">
          Get a Free Consultation
        </a>
        <a href="tel:3605292672" class="border-2 border-blue-800 text-blue-800 px-8 py-3 rounded-lg font-semibold hover:bg-blue-800 hover:text-white transition-colors">
          Call Us Today
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
