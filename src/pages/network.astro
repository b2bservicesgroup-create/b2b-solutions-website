---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const partners = [
  {
    icon: 'scale',
    category: 'Legal Services',
    subtitle: 'Attorneys & Legal Professionals',
    description: 'Access experienced business attorneys who understand the challenges small businesses face. Whether you need help forming your business, protecting your interests, or navigating employment matters, our legal network has you covered.',
    services: [
      'Business formation and structure',
      'Contract drafting and review',
      'Employment law and compliance',
      'Business dispute resolution',
      'Intellectual property protection',
      'Regulatory compliance guidance',
    ],
  },
  {
    icon: 'tax',
    category: 'Tax Services',
    subtitle: 'CPAs & Tax Professionals',
    description: 'Our network of tax professionals works hand-in-hand with our bookkeeping services to ensure your business tax situation is always optimized. From annual returns to strategic planning, they\'re ready to help.',
    services: [
      'Business and personal tax preparation',
      'Tax planning and strategy',
      'IRS representation and resolution',
      'Small business tax optimization',
      'Quarterly estimated tax planning',
      'Multi-state tax compliance',
    ],
  },
  {
    icon: 'marketing',
    category: 'Marketing & Branding',
    subtitle: 'Marketing Professionals & Agencies',
    description: 'Getting your message out there is essential for growth. Our marketing network includes digital marketers, brand strategists, web developers, and social media specialists who understand small business goals and budgets.',
    services: [
      'Brand identity and logo design',
      'Website design and development',
      'Digital marketing and SEO',
      'Social media management',
      'Content creation and copywriting',
      'Email marketing campaigns',
    ],
  },
  {
    icon: 'print',
    category: 'Print & Promotional',
    subtitle: 'Print Shops & Merchandise Creators',
    description: 'Make your brand tangible with professional print and promotional materials. Our print and merchandise partners create everything from business cards and signage to branded apparel and promotional products.',
    services: [
      'Business cards and stationery',
      'Banners, signs, and displays',
      'Branded apparel and uniforms',
      'Promotional products and giveaways',
      'Marketing collateral and flyers',
      'Custom merchandise and gifts',
    ],
  },
];

const steps = [
  {
    step: '01',
    title: 'Tell Us What You Need',
    description: 'Reach out and describe the challenge or service you\'re looking for. No need to know who to call — that\'s what we\'re here for.',
  },
  {
    step: '02',
    title: 'We Make the Introduction',
    description: 'We connect you with the right professional from our vetted network, making a warm introduction so you start the relationship with confidence.',
  },
  {
    step: '03',
    title: 'Get the Help You Need',
    description: 'Work directly with the specialist to address your needs. We stay available as your ongoing point of contact throughout.',
  },
];
---

<Layout
  title="Our Network"
  description="B2B Solutions connects small businesses with a trusted network of attorneys, tax professionals, marketing experts, and print specialists."
>
  <Header />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-blue-900 to-blue-700 text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-blue-300 text-sm font-semibold uppercase tracking-wider mb-3">Connections That Count</p>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Our Professional Network</h1>
        <p class="text-blue-100 text-lg leading-relaxed">
          B2B Solutions has built a trusted network of professionals to help with every aspect of your business. When you need a specialist, we make the introduction.
        </p>
      </div>
    </div>
  </section>

  <!-- Partners -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Our Network Partners</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Every professional in our network has been carefully vetted. We only recommend people we trust.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {partners.map(({ icon, category, subtitle, description, services }) => (
          <div class="bg-gray-50 rounded-2xl p-8 border border-gray-100">
            <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center mb-5">
              {icon === 'scale' && (
                <svg class="w-7 h-7 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
                </svg>
              )}
              {icon === 'tax' && (
                <svg class="w-7 h-7 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z" />
                </svg>
              )}
              {icon === 'marketing' && (
                <svg class="w-7 h-7 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
                </svg>
              )}
              {icon === 'print' && (
                <svg class="w-7 h-7 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-1">{category}</h3>
            <p class="text-blue-700 text-sm font-medium mb-3">{subtitle}</p>
            <p class="text-gray-600 text-sm leading-relaxed mb-5">{description}</p>
            <ul class="space-y-2">
              {services.map((s) => (
                <li class="flex items-center gap-2.5">
                  <svg class="w-4 h-4 text-blue-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  <span class="text-gray-700 text-sm">{s}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">How Our Network Works</h2>
        <p class="text-lg text-gray-600 max-w-xl mx-auto">
          Getting connected to the right professional is simple. We do the legwork so you don't have to.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {steps.map(({ step, title, description }) => (
          <div class="text-center">
            <div class="w-14 h-14 bg-blue-800 text-white rounded-full flex items-center justify-center mx-auto mb-4 text-lg font-bold">
              {step}
            </div>
            <h3 class="font-bold text-gray-900 text-lg mb-2">{title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-blue-800 text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Need a Referral?</h2>
      <p class="text-blue-200 text-lg mb-8">
        Tell us what you're looking for and we'll connect you with the right professional from our network.
      </p>
      <a href="/contact" class="inline-block bg-white text-blue-800 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors">
        Request a Referral
      </a>
    </div>
  </section>

  <Footer />
</Layout>
