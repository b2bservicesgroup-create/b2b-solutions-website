---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const values = [
  {
    icon: 'integrity',
    title: 'Integrity',
    description: 'We operate with complete honesty and transparency. You can trust that we\'ll always act in your best interest.',
  },
  {
    icon: 'partnership',
    title: 'Partnership',
    description: 'We\'re not just a vendor — we\'re your business partner. Your success is our success.',
  },
  {
    icon: 'excellence',
    title: 'Excellence',
    description: 'We hold ourselves to high professional standards in every service we deliver, every time.',
  },
  {
    icon: 'accessibility',
    title: 'Accessibility',
    description: 'Every small business deserves access to professional services. We make that possible at prices that make sense.',
  },
];
---

<Layout
  title="About Us"
  description="Learn about B2B Solutions — our mission, values, and commitment to helping small businesses in Rochester, WA and Cedar Rapids, IA."
>
  <Header />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-blue-900 to-blue-700 text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-blue-300 text-sm font-semibold uppercase tracking-wider mb-3">Our Story</p>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">About B2B Solutions</h1>
        <p class="text-blue-100 text-lg leading-relaxed">
          We believe every small business deserves access to the professional support that makes big businesses thrive.
        </p>
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">Our Mission</h2>
          <p class="text-gray-600 leading-relaxed text-lg mb-4">
            To help small businesses thrive by providing affordable access to the professional services and support that were once only available to large corporations.
          </p>
          <p class="text-gray-600 leading-relaxed">
            B2B Solutions was founded on a straightforward premise: every small business owner deserves a trusted partner in their corner. Someone who understands the challenges of running a small operation and has the expertise to help solve them.
          </p>
        </div>
        <div class="bg-blue-50 rounded-2xl p-8">
          <blockquote class="text-blue-900 text-xl font-medium leading-relaxed italic">
            "Small businesses are the backbone of our communities. When they succeed, everyone benefits. We're here to help make that happen."
          </blockquote>
          <p class="mt-4 text-blue-700 font-semibold text-sm">— B2B Solutions</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Who We Are -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-10">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Who We Are</h2>
        <p class="text-gray-600 text-lg leading-relaxed">
          B2B Solutions is a team of experienced business professionals passionate about helping small businesses succeed. We bring expertise across bookkeeping, human resources, payroll, and administrative operations — plus a curated network of specialists for everything else.
        </p>
      </div>
      <div class="grid sm:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="bg-white rounded-xl p-6 text-center shadow-sm border border-gray-100">
          <div class="text-4xl font-bold text-blue-800 mb-1">2</div>
          <div class="text-gray-600 text-sm font-medium">Locations</div>
          <div class="text-gray-500 text-xs mt-1">WA & IA</div>
        </div>
        <div class="bg-white rounded-xl p-6 text-center shadow-sm border border-gray-100">
          <div class="text-4xl font-bold text-blue-800 mb-1">5+</div>
          <div class="text-gray-600 text-sm font-medium">Core Services</div>
          <div class="text-gray-500 text-xs mt-1">Plus network referrals</div>
        </div>
        <div class="bg-white rounded-xl p-6 text-center shadow-sm border border-gray-100">
          <div class="text-4xl font-bold text-blue-800 mb-1">4</div>
          <div class="text-gray-600 text-sm font-medium">Partner Categories</div>
          <div class="text-gray-500 text-xs mt-1">In our professional network</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Our Values</h2>
        <p class="text-gray-600 text-lg max-w-xl mx-auto">
          The principles that guide everything we do at B2B Solutions.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {values.map(({ icon, title, description }) => (
          <div class="text-center p-6">
            <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-4">
              {icon === 'integrity' && (
                <svg class="w-7 h-7 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              )}
              {icon === 'partnership' && (
                <svg class="w-7 h-7 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
              )}
              {icon === 'excellence' && (
                <svg class="w-7 h-7 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
                </svg>
              )}
              {icon === 'accessibility' && (
                <svg class="w-7 h-7 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              )}
            </div>
            <h3 class="font-bold text-gray-900 text-lg mb-2">{title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Locations -->
  <section class="py-16 md:py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Where We Serve</h2>
        <p class="text-gray-600 text-lg max-w-xl mx-auto">
          Based in two locations, available everywhere.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-center">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Rochester, WA</h3>
          <p class="text-gray-500 text-sm">Pacific Northwest</p>
          <p class="text-gray-600 text-sm mt-2">
            <a href="tel:3605292672" class="text-blue-700 hover:text-blue-800 font-medium">360-529-2672</a>
          </p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-center">
          <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <h3 class="font-bold text-gray-900 mb-1">Cedar Rapids, IA</h3>
          <p class="text-gray-500 text-sm">Midwest</p>
          <p class="text-gray-600 text-sm mt-2">
            <a href="tel:3194510501" class="text-blue-700 hover:text-blue-800 font-medium">319-451-0501</a>
          </p>
        </div>
        <div class="bg-blue-800 text-white rounded-xl p-6 text-center">
          <div class="w-12 h-12 bg-white bg-opacity-20 rounded-xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
            </svg>
          </div>
          <h3 class="font-bold text-white mb-1">Remote Services</h3>
          <p class="text-blue-200 text-sm">Available Nationwide</p>
          <p class="text-blue-200 text-sm mt-2">
            Many services delivered fully remotely
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-white border-t border-gray-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">Ready to Get Started?</h2>
      <p class="text-gray-600 text-lg mb-8">
        We'd love to learn about your business and discuss how we can help.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="/contact" class="bg-blue-800 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-900 transition-colors">
          Contact Us
        </a>
        <a href="/solutions" class="border-2 border-blue-800 text-blue-800 px-8 py-3 rounded-lg font-semibold hover:bg-blue-800 hover:text-white transition-colors">
          View Our Solutions
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
