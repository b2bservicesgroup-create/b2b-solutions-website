---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}

const siteURL = 'https://b2bsolutions.biz';
const postURL = `${siteURL}/blog/${post.slug}`;

const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  url: postURL,
  datePublished: post.data.pubDate.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'B2B Solutions',
    url: siteURL,
  },
  publisher: {
    '@type': 'Organization',
    name: 'B2B Solutions',
    url: siteURL,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': postURL,
  },
};
---

<Layout title={post.data.title} description={post.data.description} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  </Fragment>
  <Header />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-blue-900 to-blue-700 text-white py-14 md:py-18">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/blog" class="inline-flex items-center gap-1.5 text-blue-300 text-sm hover:text-white transition-colors mb-6">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Blog
      </a>
      <span class="inline-block text-xs font-semibold text-blue-300 bg-white bg-opacity-10 px-3 py-1 rounded-full mb-4">
        {post.data.category}
      </span>
      <h1 class="text-3xl md:text-4xl font-bold mb-4 leading-tight">{post.data.title}</h1>
      <div class="flex items-center gap-3 text-blue-200 text-sm">
        <span>{post.data.author}</span>
        <span>&bull;</span>
        <span>{formatDate(post.data.pubDate)}</span>
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-14 md:py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="prose prose-lg prose-blue max-w-none
        prose-headings:font-bold prose-headings:text-gray-900
        prose-p:text-gray-600 prose-p:leading-relaxed
        prose-a:text-blue-700 prose-a:no-underline hover:prose-a:underline
        prose-strong:text-gray-900
        prose-ul:text-gray-600 prose-li:leading-relaxed
        prose-hr:border-gray-200">
        <Content />
      </article>

      <div class="mt-14 pt-10 border-t border-gray-200">
        <div class="bg-blue-50 rounded-2xl p-8 text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Ready to Get Help?</h3>
          <p class="text-gray-600 mb-5">
            B2B Solutions provides professional bookkeeping, HR, payroll, and administrative support for small businesses.
          </p>
          <a href="/contact" class="inline-block bg-blue-800 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-900 transition-colors">
            Schedule a Free Consultation
          </a>
        </div>
      </div>

      <div class="mt-8">
        <a href="/blog" class="inline-flex items-center gap-1.5 text-blue-700 font-semibold hover:text-blue-800 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Back to all posts
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
