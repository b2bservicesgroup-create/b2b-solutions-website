---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    id: 'bookkeeping',
    icon: 'calculator',
    title: 'Bookkeeping',
    tagline: 'Your finances — organized, accurate, and always up to date.',
    description: 'Keep your business finances in order with our professional bookkeeping services. We handle the day-to-day financial tasks so you have clear, accurate records and the information you need to make confident business decisions.',
    features: [
      'Transaction recording and categorization',
      'Bank and credit card reconciliation',
      'Accounts payable and receivable management',
      'Monthly financial statements and reports',
      'Software management (QuickBooks, Wave, Xero, and more)',
      'Year-end preparation for your tax professional',
    ],
  },
  {
    id: 'hr',
    icon: 'users',
    title: 'HR Solutions',
    tagline: 'Professional HR support — without the full-time price tag.',
    description: 'Get the HR expertise your business needs without committing to a full-time HR department. Our fractional HR services scale with your business, providing the right level of support at every stage of growth.',
    features: [
      'HR policy development and employee handbook creation',
      'Recruitment support and onboarding processes',
      'Employee relations and performance management',
      'HR compliance guidance (federal and state regulations)',
      'Benefits administration support',
      'Termination procedures and offboarding',
    ],
  },
  {
    id: 'payroll',
    icon: 'dollar',
    title: 'Payroll Administration',
    tagline: 'Accurate, on-time payroll — every pay period.',
    description: 'Managing payroll is complex and time-consuming. We handle the entire payroll process so your employees are paid correctly and on schedule, every time — while keeping you compliant with all filing requirements.',
    features: [
      'Payroll processing (weekly, bi-weekly, semi-monthly, or monthly)',
      'Federal, state, and local tax withholding and filings',
      'Direct deposit setup and management',
      'Detailed payroll reports and record keeping',
      'New hire reporting requirements',
      'W-2 and 1099 preparation and filing',
      'Processed through Cascade Payroll and Gusto',
    ],
  },
  {
    id: 'admin',
    icon: 'clipboard',
    title: 'Administrative Support',
    tagline: 'Keep operations running smoothly — virtually.',
    description: 'Free up your time with virtual administrative assistance that handles the tasks keeping you from focusing on your business. From scheduling to correspondence, we keep your operations organized and efficient.',
    features: [
      'Virtual executive and administrative assistance',
      'Calendar and schedule management',
      'Email and correspondence management',
      'Data entry and database management',
      'Meeting coordination and minutes documentation',
      'Travel arrangements and coordination',
    ],
  },
  {
    id: 'documents',
    icon: 'document',
    title: 'Document Creation & SOPs',
    tagline: 'Clear documentation that creates consistency across your business.',
    description: 'Well-written documentation is the foundation of a scalable business. We create professional documents, SOPs, and training materials that capture your processes, reduce errors, and help your team operate consistently.',
    features: [
      'Standard Operating Procedures (SOPs) development',
      'Policy and procedure manuals',
      'Employee handbooks and training materials',
      'Business proposals, reports, and presentations',
      'Process documentation and workflow design',
      'Business correspondence templates and forms',
    ],
  },
  {
    id: 'llc',
    icon: 'building',
    title: 'LLC Registration & Registered Agent',
    tagline: 'Start your business the right way — and stay compliant.',
    description: 'B2B Solutions is a registered agent in Washington State and can help you form your LLC quickly and correctly. We handle the paperwork, filing, and ongoing compliance requirements so you can focus on building your business from day one.',
    features: [
      'LLC formation and Articles of Organization filing in Washington State',
      'Registered Agent services in Washington State',
      'Registered address for official government and legal correspondence',
      'Annual report reminders and compliance support',
      'Operating agreement templates and guidance',
      'Business structure consultation (sole proprietor vs. LLC)',
    ],
  },
];
---

<Layout
  title="Solutions"
  description="Bookkeeping, fractional HR, payroll administration, administrative support, document creation, LLC formation, and registered agent services for small businesses in Washington State."
>
  <Header />

  <!-- Page Hero -->
  <section class="bg-gradient-to-br from-blue-900 to-blue-700 text-white py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <p class="text-blue-300 text-sm font-semibold uppercase tracking-wider mb-3">What We Offer</p>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Our Solutions</h1>
        <p class="text-blue-100 text-lg leading-relaxed">
          From financial management to HR strategy and administrative support, B2B Solutions provides the professional services your small business needs to operate efficiently and grow with confidence.
        </p>
      </div>
    </div>
  </section>

  <!-- Quick Nav -->
  <div class="bg-white border-b border-gray-200 sticky top-24 z-40">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="flex gap-1 overflow-x-auto py-3 scrollbar-hide" aria-label="Solution sections">
        {services.map(({ id, title }) => (
          <a
            href={`#${id}`}
            class="shrink-0 px-4 py-1.5 rounded-full text-sm font-medium text-gray-600 hover:text-blue-700 hover:bg-blue-50 transition-colors"
          >
            {title}
          </a>
        ))}
      </nav>
    </div>
  </div>

  <!-- Services -->
  {services.map(({ id, icon, title, tagline, description, features }, i) => (
    <section
      id={id}
      class={`py-16 md:py-20 scroll-mt-36 ${i % 2 === 0 ? 'bg-white' : 'bg-gray-50'}`}
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-2 gap-10 items-start">
          <div>
            <div class="w-14 h-14 bg-blue-100 rounded-xl flex items-center justify-center mb-5">
              {icon === 'calculator' && (
                <svg class="w-7 h-7 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                </svg>
              )}
              {icon === 'users' && (
                <svg class="w-7 h-7 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
              )}
              {icon === 'dollar' && (
                <svg class="w-7 h-7 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              )}
              {icon === 'clipboard' && (
                <svg class="w-7 h-7 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                </svg>
              )}
              {icon === 'document' && (
                <svg class="w-7 h-7 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
              )}
              {icon === 'building' && (
                <svg class="w-7 h-7 text-blue-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
              )}
            </div>
            <h2 class="text-3xl font-bold text-gray-900 mb-2">{title}</h2>
            <p class="text-blue-700 font-medium mb-4">{tagline}</p>
            <p class="text-gray-600 leading-relaxed mb-6">{description}</p>
            <a href="/contact" class="inline-flex items-center bg-blue-800 text-white px-5 py-2.5 rounded-lg font-semibold hover:bg-blue-900 transition-colors text-sm">
              Get Started
              <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
          <div class="bg-blue-50 rounded-2xl p-7">
            <h3 class="font-bold text-gray-900 mb-4 text-sm uppercase tracking-wider">What's Included</h3>
            <ul class="space-y-3">
              {features.map((feature) => (
                <li class="flex items-start gap-3">
                  <div class="w-5 h-5 bg-blue-700 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                    <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <span class="text-gray-700 text-sm leading-relaxed">{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="py-16 bg-blue-800 text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold mb-4">Not Sure Which Services You Need?</h2>
      <p class="text-blue-200 text-lg mb-8">
        Schedule a free consultation and we'll help you identify the right combination of services for your business.
      </p>
      <a href="/contact" class="inline-block bg-white text-blue-800 px-8 py-3 rounded-lg font-semibold hover:bg-blue-50 transition-colors">
        Schedule a Free Consultation
      </a>
    </div>
  </section>

  <Footer />
</Layout>
